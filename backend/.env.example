# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL: Settings → API → Project URL
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Service Role Key (has full DB + Storage access, bypasses RLS)
# Settings → API → Project API Keys → service_role
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# ─── Google AI (Gemini) ──────────────────────────────────────────────────────
# https://aistudio.google.com/apikey
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE

# ─── Local Directories ──────────────────────────────────────────────────────
# Temporary local storage for processing (cleaned up after upload to Supabase)
UPLOAD_DIR=./uploads
OUTPUT_DIR=./output_clips
CACHE_DIR=./cache/transcripts

# ─── Storage Bucket Names ────────────────────────────────────────────────────
VIDEOS_BUCKET=attentionx-videos
CLIPS_BUCKET=attentionx-clips
